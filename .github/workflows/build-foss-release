name: Build FOSS Release APK

on:
  push:
    branches:
      - wherigo-dev
  workflow_dispatch:

jobs:
  build:
    name: Build FOSS Release
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up JDK 11
        uses: actions/setup-java@v3
        with:
          distribution: 'temurin'
          java-version: '11'

      - name: Set up Android SDK
        uses: android-actions/setup-android@v2
        with:
          api-level: 33
          ndk: '23.1.7779620'

      - name: Cache Gradle
        uses: actions/cache@v4
        with:
          path: |
            ~/.gradle/caches
            ~/.gradle/wrapper/
          key: ${{ runner.os }}-gradle-${{ hashFiles('**/build.gradle*', '**/gradle-wrapper.properties') }}
          restore-keys: |
            ${{ runner.os }}-gradle-

      - name: Decode keystore
        if: secrets.KEYSTORE_BASE64
        run: |
          echo "${{ secrets.KEYSTORE_BASE64 }}" | base64 --decode > release.keystore

      - name: Build FOSS Release APK (signed)
        run: |
          ./gradlew --no-daemon clean assembleFossRelease \
            -Pandroid.injected.signing.store.file=${{ secrets.KEYSTORE_BASE64 && 'release.keystore' || '' }} \
            -Pandroid.injected.signing.store.password=${{ secrets.KEYSTORE_PASSWORD }} \
            -Pandroid.injected.signing.key.alias=${{ secrets.KEY_ALIAS }} \
            -Pandroid.injected.signing.key.password=${{ secrets.KEY_PASSWORD }}
        env:
          JAVA_HOME: ${{ steps.setup-java.outputs.path }}

      - name: Upload APK
        uses: actions/upload-artifact@v3
        with:
          name: cgeo-foss-release-apk
          path: app/build/outputs/apk/foss/release/*.apk

      - name: Cleanup keystore
        if: secrets.KEYSTORE_BASE64
        run: rm -f release.keystore

# Notes:
# This workflow expects the following repository secrets to sign the release APK:
# - KEYSTORE_BASE64 (base64-encoded .jks file)
# - KEYSTORE_PASSWORD
# - KEY_ALIAS
# - KEY_PASSWORD
